# Get your API key from https://cloud.browser-use.com/
BROWSER_USE_API_KEY=

# Optional: use a synced browser profile so the agent is logged into X (required for X search).
# 1) Sync cookies: export BROWSER_USE_API_KEY=your_key && curl -fsSL https://browser-use.com/profile.sh | sh
# 2) Copy your profile_id from https://cloud.browser-use.com/settings?tab=profiles
BROWSER_USE_PROFILE_ID=
