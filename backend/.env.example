# Browser Use Cloud (required)
BROWSER_USE_API_KEY=

# Anthropic (for competitor discovery: names + URLs)
ANTHROPIC_API_KEY=

# Optional: synced profile for X / LinkedIn / Instagram (logged-in sessions)
BROWSER_USE_PROFILE_ID=

# Supabase (required for auth + DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# For verifying Bearer JWT (Project Settings -> API -> JWT Secret)
SUPABASE_JWT_SECRET=

# Optional: secret for daily rescrape cron (e.g. X-Cron-Secret header)
CRON_SECRET=

# Optional: Google GenAI for draft media (Gemini image + Veo3 video)
GOOGLE_API_KEY=
